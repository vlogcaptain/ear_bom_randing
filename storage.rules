rules_version = '2';

// ear-bom-healthy 프로젝트의 스토리지 보안 규칙
service firebase.storage {
  match /b/{bucket}/o {
    
    // 전문가 권한 확인 함수 (Firestore admins 컬렉션 참조)
    function isExpert() {
      return request.auth != null && 
             firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email));
    }

    // 1. 신규 폴더 기반 구조 보안 (ear_photos/userId/filename)
    match /ear_photos/{userId}/{allPaths=**} {
      allow read, write: if isExpert() || (request.auth != null && request.auth.uid == userId);
    }

    // 2. 기존 플랫 파일 구조 보안 (ear_photos/userId_timestamp)
    // 하위 호환성을 위해 파일명에서 UID를 추출하여 본인 확인
    match /ear_photos/{photoId} {
      allow read, delete: if isExpert() || (request.auth != null && photoId.split('_')[0] == request.auth.uid);
      // 신규 업로드는 위 폴더 구조에서 처리하므로 여기서는 쓰기(create) 제한
    }

    // 3. 기본 차단 정책 (Deny by default)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
